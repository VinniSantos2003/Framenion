<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="framenion.ToastWindow"
        xmlns:local="clr-namespace:framenion"
        x:DataType="local:ToastWindow"
        Width="360"
        Height="96"
        WindowDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Background="{DynamicResource ToastBackgroundBrush}">
    <Border Padding="12">
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
            <Image Grid.Column="0" Grid.RowSpan="2" Name="IconImage"
                   Source="avares://framenion/assets/operator.png"
                   Width="64" Height="64"
                   Margin="0,0,12,0"/>
            <TextBlock Grid.Column="1" Grid.Row="0" Name="TitleText"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       Text="{Binding ToastTitle}"/>
            <TextBlock Grid.Column="1" Grid.Row="1" Name="BodyText"
                       FontSize="13"
                       Text="{Binding Body}"
                       Foreground="white"
                       TextWrapping="Wrap"/>
        </Grid>
    </Border>
</Window>
