<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:framenion"
        x:Class="framenion.RelicRewardWindow"
        x:DataType="local:RelicRewardWindow"
        WindowDecorations="None"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True"
        Background="{DynamicResource RewardWindowBackgroundBrush}"
        Width="200"
        Height="150">
    <Border Padding="12">
        <Grid RowDefinitions="*,Auto">
            <TextBlock Name="NameItem" Text="{Binding ItemName}" FontSize="15" Foreground="{DynamicResource PrimaryForegroundBrush}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            
            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10,10,10,10">
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="15">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="5">
                <Image Source="avares://framenion/assets/platinum.png" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBlock Name="PlatinumValue" Text="{Binding Price}" Foreground="{DynamicResource PrimaryForegroundBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                <Image Source="avares://framenion/assets/ducats.png" Width="24" Height="24" VerticalAlignment="Center"/>
                <TextBlock Name="DucatValue" Text="{Binding Ducats}" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryForegroundBrush}"/>
            </StackPanel>
            </Grid>
                </StackPanel>
            </Grid>
    </Border>
</Window>
