<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="framenion.SettingsWindow"
        Title="Settings"
        SizeToContent="WidthAndHeight"
        Background="{DynamicResource AppBackgroundBrush}">
  <Border Padding="20">
    <StackPanel Spacing="16">
        <Grid ColumnDefinitions="Auto, Auto" ColumnSpacing="5">
      <TextBlock Grid.Column="0" Text="Settings" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,0,8" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="1" Text="Mouse over options for more info." FontSize="13" Foreground="{DynamicResource SecondaryForegroundBrush}" Margin="0,0,0,12" VerticalAlignment="Bottom"/>
            </Grid>
      <!-- Appearance Section -->
      <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
        <StackPanel>
          <TextBlock Text="Appearance" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,0,8"/>
          <Grid ColumnDefinitions="200,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="10">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Accent Color" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" ToolTip.Tip="Accent color (e.g. #4A9EFF)"/>
            <TextBox Grid.Row="0" Grid.Column="1" Name="AccentColorBox" PlaceholderText="#4A9EFF"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Miscellaneous Section -->
      <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
        <StackPanel>
          <TextBlock Text="Miscellaneous" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryForegroundBrush}" Margin="0,0,0,8"/>
          <StackPanel Spacing="8">
            <CheckBox Name="EnableNotificationsCheckBox"
                      Content="Enable notifications"
                      Foreground="{DynamicResource SecondaryForegroundBrush}"
                      ToolTip.Tip="Enable or disable Toast notifications"/>
            <CheckBox Name="EnableEELogReadBox"
                      Content="Enable EE log reading"
                      Foreground="{DynamicResource SecondaryForegroundBrush}"
                      ToolTip.Tip="Enable real-time EE log reading.&#x0a;Disabling this will also disable automatic OCR relic rewards."/>
            <CheckBox Name="EnableRelicOverlayBox"
                      Content="Enable relic reward overlay"
                      Foreground="{DynamicResource SecondaryForegroundBrush}"
                      ToolTip.Tip="Enable OCR for relic rewards.&#x0a;The OCR will run automatically if EE log reading is enabled or by pressing printscreen key at any moment."/>
            <Grid ColumnDefinitions="Auto, Auto, auto, auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="UI scale (%):" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" ToolTip.Tip="Insert Warframe UI scale value"/>
                <NumericUpDown Grid.Column="1" Name="UiScaleNumeric" Minimum="50" Maximum="100" ShowButtonSpinner="False"/>

                <TextBlock Grid.Column="2" Text="Overlay offset:" Foreground="{DynamicResource SecondaryForegroundBrush}" VerticalAlignment="Center" ToolTip.Tip="Set relic Y overlay offset value in pixels"/>
                <NumericUpDown Grid.Column="3" Name="OverlayOffset" Minimum="0" ShowButtonSpinner="False"/>
            </Grid>
            <CheckBox Name="DebugOCRBox" Content="Enable OCR debug images" Foreground="{DynamicResource SecondaryForegroundBrush}" ToolTip.Tip="Save debug images for relic reward OCR (for troubleshooting)"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,10,0,0">
        <Button Name="CancelButton" Content="Cancel" Click="Cancel_Click"/>
        <Button Name="SaveButton" Content="Save" Click="SaveApply_Click"/>
      </StackPanel>
    </StackPanel>
  </Border>
</Window>